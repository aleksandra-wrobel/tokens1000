{
  "base/tokens/default": {
    "Base Tokens": {
      "color": {
        "primary": {
          "base": {
            "$type": "color",
            "$value": "#9ea0af"
          },
          "hover": {
            "$type": "color",
            "$value": "#70798c"
          }
        },
        "secondary": {
          "base": {
            "$type": "color",
            "$value": "#a6988b"
          },
          "hover": {
            "$type": "color",
            "$value": "#776d61"
          }
        }
      },
      "fontFamilies": {
        "inter": {
          "$type": "fontFamilies",
          "$value": "Inter"
        }
      },
      "lineHeights": {
        "0": {
          "$type": "lineHeights",
          "$value": "AUTO"
        },
        "1": {
          "$type": "lineHeights",
          "$value": "AUTO"
        }
      },
      "fontWeights": {
        "inter-0": {
          "$type": "fontWeights",
          "$value": "Bold"
        },
        "inter-1": {
          "$type": "fontWeights",
          "$value": "Regular"
        }
      },
      "fontSize": {
        "0": {
          "$type": "fontSizes",
          "$value": 32
        },
        "1": {
          "$type": "fontSizes",
          "$value": 40
        }
      },
      "letterSpacing": {
        "0": {
          "$type": "letterSpacing",
          "$value": "0%"
        }
      },
      "paragraphSpacing": {
        "0": {
          "$type": "paragraphSpacing",
          "$value": 0
        }
      },
      "font": {
        "heading": {
          "h1": {
            "$type": "typography",
            "$value": {
              "fontFamily": "{fontFamilies.inter}",
              "fontWeight": "{fontWeights.inter-0}",
              "lineHeight": "{lineHeights.0}",
              "fontSize": "{fontSize.1}",
              "letterSpacing": "{letterSpacing.0}",
              "paragraphSpacing": "{paragraphSpacing.0}",
              "paragraphIndent": "{paragraphIndent.0}",
              "textCase": "{textCase.none}",
              "textDecoration": "{textDecoration.none}"
            }
          }
        },
        "body": {
          "regular": {
            "$type": "typography",
            "$value": {
              "fontFamily": "{fontFamilies.inter}",
              "fontWeight": "{fontWeights.inter-1}",
              "lineHeight": "{lineHeights.0}",
              "fontSize": "{fontSize.0}",
              "letterSpacing": "{letterSpacing.0}",
              "paragraphSpacing": "{paragraphSpacing.0}",
              "paragraphIndent": "{paragraphIndent.0}",
              "textCase": "{textCase.none}",
              "textDecoration": "{textDecoration.none}"
            }
          }
        }
      },
      "textCase": {
        "none": {
          "$type": "textCase",
          "$value": "none"
        }
      },
      "textDecoration": {
        "none": {
          "$type": "textDecoration",
          "$value": "none"
        }
      },
      "paragraphIndent": {
        "0": {
          "$type": "dimension",
          "$value": "0px"
        }
      }
    }
  },
  "base/tokens/blue set": {
    "Blue Tokens": {
      "color": {
        "primary": {
          "base": {
            "$type": "color",
            "$value": "#0000ff"
          },
          "hover": {
            "$type": "color",
            "$value": "#0044ff"
          }
        },
        "secondary": {
          "base": {
            "$type": "color",
            "$value": "#00aaff"
          },
          "hover": {
            "$type": "color",
            "$value": "#0088cc"
          }
        }
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "base/tokens/default",
      "base/tokens/blue set"
    ]
  }
}